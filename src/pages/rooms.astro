---
export const prerender = true
import MainLayout from '../layouts/MainLayout.astro'

const roomModules = import.meta.glob('../content/rooms/*.json', { eager: true })
const rooms = Object.entries(roomModules)
  .map(([path, mod]: [string, any]) => ({
    ...mod.default,
    slug: path.split('/').pop()!.replace('.json', '')
  }))
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))
---

<MainLayout title="Rooms & Villas — Segara Villas Bali" description="Eleven private villas and suites at Segara Villas — each a unique sanctuary on the shores of Seminyak, Bali." heroImage="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=1400&q=80">

  <!-- Banner -->
  <section class="relative h-[65vh] min-h-[480px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=1400&q=80"
        alt="Rooms at Segara Villas"
        class="w-full h-full object-cover"
        fetchpriority="high"
        decoding="async">
      <div class="absolute inset-0 bg-gradient-to-t from-[#0C1B33] via-[#0C1B33]/40 to-[#0C1B33]/10"></div>
    </div>
    <div class="relative z-10 section-padding w-full pb-16 md:pb-24">
      <p class="section-subtitle mb-4">Accommodations</p>
      <h1 class="text-[#F8F4EE] font-light leading-tight"
          style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 5vw, 4.5rem);">
        Eleven Unique<br>Private Retreats.
      </h1>
    </div>
  </section>


  <!-- Rooms List -->
  <section class="py-24 md:py-32 bg-[#F8F4EE]">
    <div class="section-padding">

      <div class="flex flex-col gap-24">
        {rooms.map((room, i) => (
          <div id={room.slug} class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

            <!-- Image -->
            <div class:list={['relative overflow-hidden', i % 2 !== 0 ? 'lg:order-last' : '']}>
              <img
                src={room.image}
                alt={room.name}
                class="w-full aspect-[4/3] object-cover"
                loading="lazy"
                decoding="async">
              <div class="absolute top-5 left-5 bg-[#0C1B33] px-5 py-3">
                <p class="text-[#C9A96E] text-sm" style="font-family: 'Manrope', sans-serif;">
                  from <span class="text-2xl font-light" style="font-family: 'Cormorant Garamond', serif;">${room.price}</span> / night
                </p>
              </div>
            </div>

            <!-- Content -->
            <div class:list={[i % 2 !== 0 ? 'lg:order-first' : '']}>
              <!-- Meta -->
              <div class="flex items-center gap-6 mb-5">
                <span class="text-[#0C1B33]/40 text-xs flex items-center gap-1.5" style="font-family: 'Manrope', sans-serif;">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12h18M3 12V8a1 1 0 011-1h16a1 1 0 011 1v4M3 12v4h18v-4"/>
                  </svg>
                  {room.bed}
                </span>
                <span class="text-[#0C1B33]/40 text-xs flex items-center gap-1.5" style="font-family: 'Manrope', sans-serif;">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
                  </svg>
                  {room.size} m²
                </span>
                <span class="text-[#0C1B33]/40 text-xs flex items-center gap-1.5" style="font-family: 'Manrope', sans-serif;">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  Up to {room.guests} guests
                </span>
              </div>

              <h2 class="text-3xl md:text-4xl font-light text-[#0C1B33] mb-5"
                  style="font-family: 'Cormorant Garamond', serif;">{room.name}</h2>
              <p class="text-[#0C1B33]/60 text-sm leading-relaxed mb-8"
                 style="font-family: 'Inter', sans-serif;">{room.description}</p>

              <!-- Features -->
              <div class="mb-8">
                <p class="text-[0.6rem] uppercase tracking-[0.35em] text-[#0C1B33]/40 mb-4"
                   style="font-family: 'Manrope', sans-serif;">Room Features</p>
                <div class="grid grid-cols-2 gap-2">
                  {room.features.map(f => (
                    <div class="flex items-center gap-2">
                      <span class="w-1 h-1 rounded-full bg-[#C9A96E] shrink-0"></span>
                      <span class="text-xs text-[#0C1B33]/60" style="font-family: 'Inter', sans-serif;">{f}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Includes -->
              <div class="mb-10 p-6 bg-white">
                <p class="text-[0.6rem] uppercase tracking-[0.35em] text-[#0C1B33]/40 mb-4"
                   style="font-family: 'Manrope', sans-serif;">Package Includes</p>
                <ul class="flex flex-col gap-2">
                  {room.includes.map(item => (
                    <li class="flex items-start gap-2">
                      <svg class="w-3.5 h-3.5 text-[#C9A96E] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span class="text-xs text-[#0C1B33]/60" style="font-family: 'Inter', sans-serif;">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <a href="/contact" class="btn-primary">Book This Room</a>
            </div>

          </div>
        ))}
      </div>

    </div>
  </section>

</MainLayout>
