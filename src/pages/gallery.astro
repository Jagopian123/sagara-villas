---
import MainLayout from '../layouts/MainLayout.astro'

const images = [
  { src: 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1200&q=80', alt: 'Infinity pool overlooking the ocean' },
  { src: 'https://images.unsplash.com/photo-1540541338537-71e5e37ad9f3?w=1200&q=80', alt: 'Aerial view of Bali coastline' },
  { src: 'https://images.unsplash.com/photo-1510414842594-a61c69b5ae57?w=1200&q=80', alt: 'Bali sunset' },
  { src: 'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=1200&q=80', alt: 'Private pool villa' },
  { src: 'https://images.unsplash.com/photo-1529290130-4ca3753253ae?w=1200&q=80', alt: 'Spa treatment' },
  { src: 'https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=1200&q=80', alt: 'Beachfront' },
  { src: 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=1200&q=80', alt: 'Ocean view room' },
  { src: 'https://images.unsplash.com/photo-1445019980597-93fa8acb246c?w=1200&q=80', alt: 'Fine dining' },
  { src: 'https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=1200&q=80', alt: 'Balinese culture' },
  { src: 'https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?w=1200&q=80', alt: 'Beach villa' },
  { src: 'https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?w=1200&q=80', alt: 'Resort exterior' },
  { src: 'https://images.unsplash.com/photo-1615460549969-36fa19521a4f?w=1200&q=80', alt: 'Honeymoon suite' },
]
---

<MainLayout title="Gallery — Segara Villas Bali" description="A visual journey through Segara Villas — pool, villas, dining, spa, sunsets, and the beauty of Seminyak, Bali.">

  <!-- Banner -->
  <section class="relative h-[65vh] min-h-[480px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1540541338537-71e5e37ad9f3?w=1920&q=85"
        alt="Segara Villas Gallery"
        class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-gradient-to-t from-[#0C1B33] via-[#0C1B33]/30 to-[#0C1B33]/10"></div>
    </div>
    <div class="relative z-10 section-padding w-full pb-16 md:pb-24">
      <p class="section-subtitle mb-4">Visual Stories</p>
      <h1 class="text-[#F8F4EE] font-light leading-tight"
          style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 5vw, 4.5rem);">
        Through Our Lens.
      </h1>
    </div>
  </section>


  <!-- Gallery with Lightbox -->
  <section
    class="py-24 md:py-32 bg-[#F8F4EE]"
    x-data={`{
      lightbox: false,
      activeIndex: 0,
      images: ${JSON.stringify(images)},
      open(i) { this.activeIndex = i; this.lightbox = true },
      prev() { this.activeIndex = (this.activeIndex - 1 + this.images.length) % this.images.length },
      next() { this.activeIndex = (this.activeIndex + 1) % this.images.length }
    }`}
    @keydown.escape.window="lightbox = false"
    @keydown.arrow-left.window="if(lightbox) prev()"
    @keydown.arrow-right.window="if(lightbox) next()">

    <div class="section-padding">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4">
        <div>
          <p class="section-subtitle mb-4">Our Property</p>
          <h2 class="section-title">A Glimpse of<br>Paradise.</h2>
        </div>
        <p class="text-[#0C1B33]/40 text-sm" style="font-family: 'Inter', sans-serif;">
          {images.length} photographs
        </p>
      </div>

      <!-- Masonry Grid -->
      <div class="columns-2 md:columns-3 lg:columns-4 gap-4">
        {images.map((img, i) => (
          <div
            class="break-inside-avoid mb-4 overflow-hidden group cursor-pointer relative"
            @click={`open(${i})`}>
            <img
              src={img.src}
              alt={img.alt}
              class="w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy">
            <div class="absolute inset-0 bg-[#0C1B33]/0 group-hover:bg-[#0C1B33]/40 transition-colors duration-500 flex items-center justify-center">
              <svg class="w-8 h-8 text-[#F8F4EE] opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
              </svg>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Lightbox -->
    <div
      x-show="lightbox"
      x-transition:enter="transition-opacity duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition-opacity duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      style="display: none;"
      class="fixed inset-0 z-[100] bg-[#0C1B33]/96 flex items-center justify-center p-4"
      @click.self="lightbox = false">

      <!-- Close -->
      <button @click="lightbox = false"
              class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center text-[#F8F4EE]/60 hover:text-[#C9A96E] transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- Prev -->
      <button @click="prev()"
              class="absolute left-4 md:left-8 w-12 h-12 flex items-center justify-center border border-[#F8F4EE]/20 text-[#F8F4EE]/60 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <!-- Image -->
      <div class="max-w-5xl max-h-[85vh] flex items-center justify-center">
        <img :src="images[activeIndex].src" :alt="images[activeIndex].alt"
             class="max-w-full max-h-[85vh] object-contain">
      </div>

      <!-- Next -->
      <button @click="next()"
              class="absolute right-4 md:right-8 w-12 h-12 flex items-center justify-center border border-[#F8F4EE]/20 text-[#F8F4EE]/60 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      <!-- Counter + Caption -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-center">
        <p class="text-[#F8F4EE]/40 text-xs mb-1" style="font-family: 'Inter', sans-serif;"
           x-text="images[activeIndex].alt"></p>
        <p class="text-[#F8F4EE]/30 text-xs" style="font-family: 'Manrope', sans-serif;">
          <span x-text="activeIndex + 1"></span> / <span x-text="images.length"></span>
        </p>
      </div>

    </div>

  </section>

</MainLayout>
