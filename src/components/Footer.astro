---
const links = [
  { href: '/',        label: 'Home' },
  { href: '/about',   label: 'About' },
  { href: '/rooms',   label: 'Rooms' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
]
---

<footer class="bg-[#0C1B33] text-[#F8F4EE]">

  <!-- Main Footer -->
  <div class="section-padding py-20 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <p class="text-3xl font-light tracking-[0.2em] mb-2"
           style="font-family: 'Cormorant Garamond', serif;">SEGARA</p>
        <p class="text-[0.5rem] uppercase tracking-[0.55em] text-[#C9A96E] mb-6"
           style="font-family: 'Manrope', sans-serif;">Villas · Bali</p>
        <p class="text-[#F8F4EE]/50 text-sm leading-relaxed"
           style="font-family: 'Inter', sans-serif;">
          A sanctuary of luxury nestled along the golden shores of Seminyak, Bali.
        </p>
        <!-- Social -->
        <div class="flex gap-4 mt-8">
          <a href="#" class="w-9 h-9 border border-[#F8F4EE]/20 flex items-center justify-center text-[#F8F4EE]/50 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 border border-[#F8F4EE]/20 flex items-center justify-center text-[#F8F4EE]/50 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 border border-[#F8F4EE]/20 flex items-center justify-center text-[#F8F4EE]/50 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="section-subtitle mb-8">Explore</p>
        <ul class="flex flex-col gap-4">
          {links.map(link => (
            <li>
              <a href={link.href}
                 class="text-[#F8F4EE]/50 text-sm hover:text-[#C9A96E] transition-colors duration-300"
                 style="font-family: 'Inter', sans-serif;">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="section-subtitle mb-8">Find Us</p>
        <div class="flex flex-col gap-5">
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-[#C9A96E] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-[#F8F4EE]/50 text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Jl. Kayu Aya No. 12<br>Seminyak, Bali 80361
            </p>
          </div>
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-[#C9A96E] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:hello@segaravillas.com"
               class="text-[#F8F4EE]/50 text-sm hover:text-[#C9A96E] transition-colors"
               style="font-family: 'Inter', sans-serif;">
              hello@segaravillas.com
            </a>
          </div>
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-[#C9A96E] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+62361123456"
               class="text-[#F8F4EE]/50 text-sm hover:text-[#C9A96E] transition-colors"
               style="font-family: 'Inter', sans-serif;">
              +62 361 123 456
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-[#F8F4EE]/10">
    <div class="section-padding py-6 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-[#F8F4EE]/30 text-xs" style="font-family: 'Inter', sans-serif;">
        &copy; 2025 Segara Villas. All rights reserved.
      </p>
      <p class="text-[#F8F4EE]/30 text-xs" style="font-family: 'Inter', sans-serif;">
        Seminyak, Bali, Indonesia
      </p>
    </div>
  </div>

</footer>
